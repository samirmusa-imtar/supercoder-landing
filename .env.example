# Supercoder AI Landing — Production Environment Variables
# Copy to .env on the server and fill in values. Never commit .env.

# Database (required for lead persistence)
# Run `npx prisma migrate deploy` after setting this so the SQLite file exists; then /api/health and the lead form work.
DATABASE_URL="file:./prisma/dev.db"

# Admin CSV export: set a long random token; pass as Authorization: Bearer <token>
ADMIN_API_TOKEN=""

# --- Email: choose SES or SMTP ---

# AWS SES (preferred)
AWS_REGION="eu-central-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SES_FROM_EMAIL="noreply@yourdomain.com"
SES_SALES_TO_EMAIL="sales@yourdomain.com"

# SMTP fallback (optional; used if SES not configured)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@yourdomain.com"
# SALES_EMAIL="sales@yourdomain.com"

# Send auto-reply to lead after submit (optional)
# SEND_AUTO_REPLY="true"

# --- Optional: data retention (cron script uses this) ---
# LEAD_RETENTION_MONTHS="24"
